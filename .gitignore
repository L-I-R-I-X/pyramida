```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Logs and temp files
*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Build directories
dist/
build/
target/

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.coverage
htmlcov/
.coverage.*
.cache
.pytest_cache/
.mypy_cache/
*.egg-info/
.eggs/

# Web specific
*.min.js
*.min.css
.sass-cache/
.npm/
.yarn/
bower_components/

# Java/Gradle
*.class
*.jar
*.war
*.ear
.gradle/
build/
target/

# C/C++
*.o
*.a
*.so
*.dll
*.exe
*.out
*.obj

# Compression
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
